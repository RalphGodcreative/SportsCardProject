# Database Configuration
spring.datasource.url=${DB_URL}
spring.datasource.username=postgres
spring.datasource.password=${DB_PASSWORD}

spring.jpa.hibernate.ddl-auto=validate
spring.flyway.baseline-on-migrate=true
spring.flyway.baseline-version=1

# Thymeleaf Configuration
spring.thymeleaf.cache=false
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.mode=HTML

# Email Configuration
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${GMAIL_USERNAME}
spring.mail.password=${GMAIL_APP_PASSWORD}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Static Resources
spring.web.resources.static-locations=classpath:/static/

# YouTube API
youtube.api.key=${YOUTUBE_API_KEY}

# Gemini API
gemini.api.key=${GEMINI_API_KEY}

# eBay Browse API
# Get these from developer.ebay.com → Application Keys
ebay.client.id=${EBAY_CLIENT_ID}
ebay.client.secret=${EBAY_CLIENT_SECRET}
ebay.api.base-url=https://api.ebay.com

app.registration.enabled=false

server.servlet.session.timeout=2d
